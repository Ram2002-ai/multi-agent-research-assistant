# Core providers
OPENROUTER_API_KEY=
SERPER_API_KEY=
DEFAULT_LLM=openrouter/meta-llama/llama-3.3-70b-instruct
FALLBACK_LLM=

# Platform
APP_ENV=development
DATABASE_URL=sqlite:///data/research_platform.db
JWT_SECRET=replace-with-at-least-32-random-bytes
AUTH_REQUIRED=false
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
RETRY_COUNT=2
REQUEST_TIMEOUT=300
NUMBER_OF_SOURCES=10
CHUNK_SIZE=900
VECTOR_DB=local

# PostgreSQL production example
# DATABASE_URL=postgresql+psycopg://research:password@postgres:5432/research

# Optional social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_SUCCESS_URL=http://localhost:4173
